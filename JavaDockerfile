FROM amazoncorretto:17

WORKDIR /sandbox

# Скрипт-запускатор: принимает имя класса, компилирует, выполняет с input
RUN printf '%s\n' \
    '#!/bin/bash' \
    'cd /sandbox' \
    'javac Main.java 2> compile_err.log' \
    'if [ $? -ne 0 ]; then' \
    '    cat compile_err.log' \
    '    exit 1' \
    'fi' \
    'java Main < input.txt' \
    > /run.sh && chmod +x /run.sh

# Контейнер просто ждёт команды (не завершается)
CMD ["tail", "-f", "/dev/null"]