FROM amazoncorretto:17-alpine

WORKDIR /sandbox

RUN printf '%s\n' \
    '#!/bin/sh' \
    'cd /sandbox' \
    'javac Main.java 2> compile_err.log' \
    'if [ $? -ne 0 ]; then' \
    '    cat compile_err.log' \
    '    exit 1' \
    'fi' \
    'java Main < input.txt' \
    > /run.sh && chmod +x /run.sh

CMD ["tail", "-f", "/dev/null"]