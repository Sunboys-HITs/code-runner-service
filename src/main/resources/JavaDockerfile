FROM amazoncorretto:17-alpine

WORKDIR /sandbox

# Скрипт-запускатор: принимает имя класса, компилирует, выполняет с input
RUN echo '#!/bin/bash\n\
cd /sandbox\n\
javac Main.java 2> compile_err.log\n\
if [ $? -ne 0 ]; then\n\
    cat compile_err.log\n\
    exit 1\n\
fi\n\
java Main < input.txt\n\
' > /run.sh && chmod +x /run.sh

# Контейнер просто ждёт команды (не завершается)
CMD ["tail", "-f", "/dev/null"]