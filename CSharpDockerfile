FROM mcr.microsoft.com/dotnet/sdk:8.0-alpine
WORKDIR /sandbox

RUN printf '%s\n' '<Project Sdk="Microsoft.NET.Sdk"><PropertyGroup><OutputType>Exe</OutputType><TargetFramework>net8.0</TargetFramework><ImplicitUsings>enable</ImplicitUsings></PropertyGroup></Project>' > /sandbox/runner.csproj

RUN dotnet restore runner.csproj

RUN printf '%s\n' \
    '#!/bin/sh' \
    'cd /sandbox' \
    'mv main.cs Program.cs 2>/dev/null || true' \
    'dotnet build --no-restore -c Release -o /sandbox/out >/dev/null 2>&1' \
    'if [ $? -ne 0 ]; then dotnet build --no-restore -c Release -o /sandbox/out; exit 1; fi' \
    'dotnet /sandbox/out/runner.dll < input.txt' \
    > /run.sh && chmod +x /run.sh

CMD ["tail", "-f", "/dev/null"]